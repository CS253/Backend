// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  firebaseUid     String?       @unique
  email           String        @unique
  passwordHash    String?
  name            String?
  phoneNumber     String?
  upiId           String?
  createdAt       DateTime      @default(now())
  groups          GroupMember[]
  createdGroups   Group[]
  expensesPaid    Expense[]
  splits          ExpenseSplit[]
}

model Group {
  id                      String        @id @default(uuid())
  title                   String
  inviteLink              String        @unique
  inviteLinkStatus        String        @default("ACTIVE")  // ACTIVE or REVOKED
  createdBy               String
  creator                 User          @relation(fields: [createdBy], references: [id])
  currency                String        // Auto-detected from IP, user-overrideable, defaults to INR
  preAddedParticipants    Json          @default("[]")      // Array of participant names ["Alice", "Bob"]
  simplifyDebts           Boolean       @default(false)     // If true, use greedy algorithm; if false, use netting (preserves relationships)
  createdAt               DateTime      @default(now())
  members                 GroupMember[]
  expenses                Expense[]
  settlements             Settlement[]
  transactions            Transaction[]
  media                   Media[]
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())
}

model Expense {
  id         String         @id @default(uuid())
  title      String
  amount     Float
  currency   String         @default("USD")
  groupId    String
  group      Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy     String
  payer      User           @relation(fields: [paidBy], references: [id])
  date       DateTime       @default(now())
  notes      String?
  splitType  String         @default("EQUAL")
  splits     ExpenseSplit[]
  createdAt  DateTime       @default(now())
}

model ExpenseSplit {
  id        String  @id @default(uuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  amount    Float
}

model Settlement {
  id         String    @id @default(uuid())
  fromUserId String
  toUserId   String
  groupId    String
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  amount     Float
  currency   String    @default("USD")
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Transaction {
  id         String    @id @default(uuid())
  type       String    // "EXPENSE" or "REIMBURSEMENT"
  groupId    String
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUserId String?   // null for expenses, set for reimbursements
  toUserId   String?   // null for expenses, set for reimbursements
  amount     Float
  currency   String    @default("USD")
  date       DateTime  @default(now())
  createdAt  DateTime  @default(now())
}

model Media {
  id         String   @id @default(uuid())
  fileURL    String
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploadedBy String
  createdAt  DateTime @default(now())
}
