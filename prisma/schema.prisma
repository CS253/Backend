// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String        @id @default(uuid())
  email                   String        @unique
  passwordHash            String
  name                    String?
  upiId                   String?
  phone                   String?
  address                 String?
  imageUrl                String?
  notificationsEnabled    Boolean       @default(true)
  createdAt               DateTime      @default(now())
  groups                  GroupMember[]
  createdGroups           Group[]
  expensesPaid            Expense[]     @relation("ExpensesPaid")
  splits                  ExpenseSplit[]
  settlementsFrom         Settlement[]  @relation("SettlementFromUser")
  settlementsTo           Settlement[]  @relation("SettlementToUser")
  settlementConfirmations Settlement[]  @relation("SettlementConfirmedBy")
}

model Group {
  id         String        @id @default(uuid())
  title      String
  inviteLink String        @unique
  createdBy  String
  creator    User          @relation(fields: [createdBy], references: [id])
  createdAt  DateTime      @default(now())
  members    GroupMember[]
  expenses   Expense[]
  settlements Settlement[]
  media      Media[]
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id])
  joinedAt DateTime @default(now())

  @@unique([userId, groupId])
}

model Expense {
  id      String         @id @default(uuid())
  title   String
  amount  Float
  groupId String
  group   Group          @relation(fields: [groupId], references: [id])
  paidBy  String
  payer   User           @relation("ExpensesPaid", fields: [paidBy], references: [id])
  date    DateTime       @default(now())
  splits  ExpenseSplit[]
}

model ExpenseSplit {
  id        String  @id @default(uuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  amount    Float

  @@index([expenseId, userId])
}

model Settlement {
  id              String            @id @default(uuid())
  fromUserId      String
  fromUser        User              @relation("SettlementFromUser", fields: [fromUserId], references: [id])
  toUserId        String
  toUser          User              @relation("SettlementToUser", fields: [toUserId], references: [id])
  groupId         String
  group           Group             @relation(fields: [groupId], references: [id])
  amount          Float
  method          SettlementMethod  @default(MANUAL)
  status          SettlementStatus  @default(PENDING)
  transactionId   String?
  notes           String?
  upiUrl          String?
  initiatedAt     DateTime          @default(now())
  paidAt          DateTime?
  confirmedAt     DateTime?
  confirmedBy     String?
  confirmedByUser User?             @relation("SettlementConfirmedBy", fields: [confirmedBy], references: [id])
  isPaid          Boolean           @default(false)

  @@index([groupId, status])
  @@index([fromUserId, toUserId, groupId])
}

model Media {
  id         String   @id @default(uuid())
  fileURL    String
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id])
  uploadedBy String
  createdAt  DateTime @default(now())
}

enum SettlementMethod {
  UPI
  MANUAL
}

enum SettlementStatus {
  PENDING
  COMPLETED
  CANCELLED
}
